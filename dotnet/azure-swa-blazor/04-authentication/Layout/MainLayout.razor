@inherits LayoutComponentBase

<div class="page">
    <header>
        <AuthorizeView>
            <Authorized>
                Hello, @context.User.Identity?.Name!
                <a href="/.auth/logout?post_logout_redirect_uri=/">Sign out</a>
            </Authorized>
            <NotAuthorized>
                <a href="/.auth/login/github">Sign in with GitHub</a>
            </NotAuthorized>
        </AuthorizeView>
    </header>
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
